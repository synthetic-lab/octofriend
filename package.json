{
	"name": "octofwen",
	"version": "0.0.53",
	"license": "MIT",
	"repository": "github:synthetic-lab/octofwen",
	"bin": {
		"octofriend": "packages/octofwen-cli/src/bin.ts",
		"octofwen": "packages/octofwen-cli/src/bin.ts",
		"octo": "packages/octofwen-cli/src/bin.ts",
		"octofwen-agentd": "packages/octofwen-cli/bin/octofwen-agentd.js"
	},
	"type": "module",
	"preferGlobal": true,
	"engines": {
		"bun": ">=1.3.14"
	},
	"scripts": {
		"build": "bun run typecheck",
		"biome:check": "biome check --write --unsafe --max-diagnostics 16384",
		"biome:format": "biome format --write --max-diagnostics 16384",
		"biome:lint": "biome lint --write --max-diagnostics 16384",
		"dev": "bun --watch packages/octofwen-cli/src/bin.ts",
		"exec": "bun packages/octofwen-cli/src/bin.ts",
		"test": "bun test",
		"test:run": "bun test",
		"typecheck": "tsc --noEmit -p tsconfig.json && bun run --filter \"@octofwen/*\" typecheck",
		"prepublishOnly": "bun run build",
		"prepack": "bun run --filter \"@octofwen/octofwen-cli\" build:agentd"
	},
	"files": [
		"packages",
		"crates",
		"Cargo.toml",
		"Cargo.lock",
		"CHANGELOG.md",
		"IN-APP-UPDATES.txt",
		"package.json",
		"tsconfig.json"
	],
	"dependencies": {
		"@commander-js/extra-typings": "^15.0.0",
		"antipattern": "^0.0.7",
		"chalk": "^5.6.2",
		"cli-spinners": "^3.4.0",
		"clipboardy": "^5.3.1",
		"commander": "^15.0.0",
		"diff": "^9.0.0",
		"figlet": "^1.11.0",
		"figures": "^6.1.0",
		"highlight.js": "^11.11.1",
		"html-to-text": "^10.0.0",
		"ignore": "^7.0.5",
		"ink": "^7.1.0",
		"json5": "^2.2.3",
		"marked": "^18.0.5",
		"react": "^19.2.7",
		"shell-quote": "^1.9.0",
		"string-width": "^8.2.1",
		"to-rotated": "^1.0.0",
		"toasted-notifier": "^10.1.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/figlet": "^1.7.0",
		"@types/html-to-text": "^9.0.4",
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/shell-quote": "^1.7.5",
		"ink-testing-library": "^4.0.0",
		"parse-git-diff": "^0.0.20",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"@biomejs/biome": "2.5.2"
	},
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"packages/*"
	]
}
