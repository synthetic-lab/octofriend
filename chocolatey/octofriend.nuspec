    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Fast coding agent with ACP support.</description>
    <tags>ai coding-agent acp cli</tags>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
